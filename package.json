{
  "name": "future-media-challenge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "test": "pnpm -r run test",
    "dev": "docker compose up -d db && pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter api run dev",
    "dev:web": "pnpm --filter web run dev",
    "db": "docker compose up -d db",
    "db:stop": "docker compose down",
    "prod": "docker compose --profile prod up --build",
    "prod:build": "docker compose --profile prod build",
    "generate": "pnpm --filter api generate:openapi && pnpm --filter web generate:client",
    "generate:openapi": "pnpm --filter api generate:openapi",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0"
  }
}