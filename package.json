{
  "name": "future-media-challenge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "pnpm -r run test",
    "dev": "docker compose up",
    "dev:watch": "docker compose watch",
    "dev:build": "docker compose up --build",
    "dev:rebuild": "docker compose down && docker volume rm -f future-media-challenge_api_root_modules future-media-challenge_api_modules future-media-challenge_web_root_modules future-media-challenge_web_modules && docker compose up --build",
    "generate": "pnpm --filter api generate:openapi && pnpm --filter web generate:client",
    "generate:openapi": "pnpm --filter api generate:openapi",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0"
  }
}